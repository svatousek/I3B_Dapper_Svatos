<Window x:Class="I3B_Dapper_Svatoš.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Label Content="TABLE NAME:" FontSize="20" FontFamily="Garamond" />
                <TextBox x:Name="txtTableName" Width="200" Height="30" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                <Button x:Name="btnCreateTable" Content="Vytvoř tabulku" Width="150" Height="30" Click="btnCreateTable_Click"/>
            </StackPanel>

            <Label Content="INSERT INTO" HorizontalAlignment="Center" FontSize="20" FontFamily="Garamond"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="Tabulka:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtInsertTable" Width="120" Height="30" Margin="5"/>
                <TextBlock Text="Sloupec:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtColumn" Width="120" Height="30" Margin="5"/>
                <TextBlock Text="Hodnota:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtData" Width="150" Height="30" Margin="5"/>
                <Button Content="Insert" Width="100" Height="30" Margin="5" Click="btnInsert_Click"/>
            </StackPanel>



            <Label Content="SELECT * FROM" HorizontalAlignment="Center" FontSize="20" FontFamily="Garamond"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="Tabulka:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="" HorizontalAlignment="Center" FontSize="14" Width="120" Height="30" Margin="5"/>
                <Button x:Name="btnLoad" Content="Načti data" Width="120" Height="30" HorizontalAlignment="Center" Click="btnLoad_Click"/>
            </StackPanel>
            
           
        </StackPanel>
        
        <DataGrid x:Name="dgMediaType" Grid.Row="1" Margin="10" AutoGenerateColumns="True" IsReadOnly="True"/>
    </Grid>
</Window>