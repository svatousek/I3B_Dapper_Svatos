<Window x:Class="I3B_Dapper_Svatoš.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:I3B_Dapper_Svatoš"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,10">
            <Button x:Name="btnLoad"
            Content="Načti data"
            Width="120"
            Height="30"
            HorizontalAlignment="Center"
            Click="btnLoad_Click"/>
            </StackPanel>
            <DataGrid x:Name="dgMediaType" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"></DataGrid>

        
    </Grid>
</Window>
